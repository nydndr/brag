---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Submit — \brag pages"
  description="Submit your /brag page to the public directory."
  hideFooter={true}
>
  <div class="max-w-6xl">
    <div>
      <h1 class="text-9xl tracking-tight font-semibold leading-tight mb-2 text-blue-500/15">
        Submit
      </h1>
    </div>

    <div class="leading-loose mt-10 grid grid-cols-2 gap-12">
      <article id="how-to-submit" class="space-y-4">
        <h2 class="text-2xl font-semibold text-blue-500">How to submit</h2>

        <ol class="space-y-6">
          <li class="space-y-1">
            <h3 class="text-xl text-zinc-400">1. Fork the repository</h3>
            <p class="w-4/5">
              Start by forking the <a
                href="https://github.com/nydndr/brag"
                target="_blank"
                rel="noopener noreferrer"
                class="text-blue-500">repository on GitHub</a
              >. This creates your own copy to make changes in.
            </p>
          </li>

          <li class="space-y-1">
            <h3 class="text-xl text-zinc-400">2. Add your entry</h3>
            <p class="w-4/5">
              Open <code class="text-xs font-mono bg-gray-100 px-1 py-0.5">src/data/brags.json</code
              > and paste your generated JSON at the end of the array.
            </p>
          </li>

          <li class="space-y-1">
            <h3 class="text-xl text-zinc-400">3. Open a pull request</h3>
            <p class="w-4/5">
              Open a pull request titled <code class="text-xs font-mono bg-gray-100 px-1 py-0.5"
                >Add [Your Name]</code
              >. That's it — no account needed beyond GitHub.
            </p>
          </li>
        </ol>
      </article>

      <article id="your-entry" class="space-y-4">
        <h2 class="text-2xl font-semibold text-blue-500">Your entry</h2>

        <div class="space-y-4">
          <div>
            <label for="f-name" class="block text-sm font-medium text-gray-700 mb-1">Name</label>
            <input
              id="f-name"
              type="text"
              placeholder="Your name"
              class="w-full border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <label for="f-url" class="block text-sm font-medium text-gray-700 mb-1">Brag URL</label>
            <input
              id="f-url"
              type="url"
              placeholder="https://yoursite.com/brag"
              class="w-full border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
            />
          </div>
          <div>
            <div class="flex justify-between mb-1">
              <label for="f-desc" class="block text-sm font-medium text-gray-700">Description</label
              >
              <span id="char-count" class="text-xs text-gray-400">0 / 200</span>
            </div>
            <textarea
              id="f-desc"
              placeholder="Who you are and what you do. Keep it under 200 characters."
              rows="3"
              maxlength="200"
              class="w-full border border-gray-200 px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
            ></textarea>
          </div>
        </div>

        <div class="rounded overflow-hidden border border-gray-100">
          <div class="flex items-center justify-between bg-gray-900 px-4 py-2.5">
            <span class="text-xs font-mono text-gray-400">your entry</span>
            <button
              id="copy-btn"
              class="text-xs text-gray-400 hover:text-white transition-colors font-medium"
            >
              Copy
            </button>
          </div>
          <pre
            id="json-output"
            class="bg-gray-950 text-green-400 px-5 py-4 text-sm font-mono leading-relaxed overflow-x-auto">{`{
  "name": "",
  "brag_url": "",
  "description": ""
}`}</pre>
        </div>
        <p class="text-xs text-gray-400">
          Paste this object at the end of the array in <code class="font-mono"
            >src/data/brags.json</code
          >
        </p>
      </article>
    </div>
  </div>
</BaseLayout>

<script>
  const nameInput = document.getElementById('f-name') as HTMLInputElement;
  const urlInput = document.getElementById('f-url') as HTMLInputElement;
  const descInput = document.getElementById('f-desc') as HTMLTextAreaElement;
  const charCount = document.getElementById('char-count')!;
  const jsonOutput = document.getElementById('json-output')!;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;

  function updateJson() {
    const entry = {
      name: nameInput.value,
      brag_url: urlInput.value,
      description: descInput.value,
    };
    jsonOutput.textContent = JSON.stringify(entry, null, 2);
  }

  function updateCharCount() {
    const len = descInput.value.length;
    charCount.textContent = `${len} / 200`;
    charCount.className =
      len > 180 ? 'text-xs text-orange-500 font-medium' : 'text-xs text-gray-400';
  }

  nameInput.addEventListener('input', updateJson);
  urlInput.addEventListener('input', updateJson);
  descInput.addEventListener('input', () => {
    updateJson();
    updateCharCount();
  });

  copyBtn.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(jsonOutput.textContent ?? '');
      copyBtn.textContent = 'Copied!';
    } catch {
      copyBtn.textContent = 'Error';
    }
    setTimeout(() => {
      copyBtn.textContent = 'Copy';
    }, 2000);
  });
</script>
