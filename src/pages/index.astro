---
import BaseLayout from '../layouts/BaseLayout.astro';
import BragList from '../components/BragList.astro';
import type { BragEntry } from '../types/brag';
import bragsData from '../data/brags.json';

const entries = bragsData as BragEntry[];
const count = entries.length;
---

<BaseLayout
  title="/brag pages"
  description="A public collection of all brag pages — the real resumé of your wins, projects and who you are."
>
  <div class="grid grid-cols-3 font-display">
    <div class="col-span-2 space-y-4">
      <p class="text-blue-500 leading-relaxed max-w-xl text-2xl w-4/5">
        A collection of every personal website with \brag a page, submitted by you.
      </p>
    </div>
    <div class="col-span-1">
      <div class="flex flex-col gap-4 text-gray-400 items-end text-sm">
        <a
          href="/submit"
          class="border-gray-400/60 border-b w-48 hover:text-blue-500 hover:border-blue-500 transition-colors"
          >What is a /brag page</a
        >
        <a
          href="/submit"
          class="border-gray-400/60 border-b w-48 hover:text-blue-500 hover:border-blue-500 transition-colors"
          >How to submit</a
        >
      </div>
    </div>
  </div>

  <div class="mt-8">
    <p class="text-xs text-gray-400 mt-5 my-6 text-right">
      <span id="counter" class="font-mono inline-flex" data-target={count}></span>
      {count === 1 ? 'brag listed' : 'brags listed'}
    </p>
    <div
      class="flex items-center gap-4 py-2 px-3 text-xs text-gray-400 uppercase tracking-wider border-b border-gray-200 font-display"
    >
      <span class="w-32 shrink-0">Name</span>
      <span class="flex-1">Description</span>
      <span class="w-44 shrink-0 text-right">Page</span>
    </div>

    <BragList entries={entries} />
  </div>
</BaseLayout>

<script>
  const el = document.getElementById('counter');
  if (el) {
    const target = parseInt(el.dataset.target ?? '0', 10);
    const digits = String(target).split('');
    const LINE_HEIGHT = 1.5; // em, matches leading

    el.style.color = 'rgb(59, 130, 246)';

    digits.forEach((digitStr, i) => {
      const digit = parseInt(digitStr);

      // Two full spins (0–9 twice) then land on target digit
      const items: number[] = [];
      for (let round = 0; round < 2; round++) {
        for (let n = 0; n <= 9; n++) items.push(n);
      }
      for (let n = 0; n <= digit; n++) items.push(n);

      const slot = document.createElement('span');
      slot.style.cssText = `display:inline-block; overflow:hidden; height:${LINE_HEIGHT}em; line-height:${LINE_HEIGHT}em; vertical-align:bottom;`;

      const track = document.createElement('span');
      track.style.cssText = 'display:flex; flex-direction:column; will-change:transform;';

      items.forEach(n => {
        const span = document.createElement('span');
        span.textContent = String(n);
        span.style.height = `${LINE_HEIGHT}em`;
        track.appendChild(span);
      });

      slot.appendChild(track);
      el.appendChild(slot);

      // Stagger each digit slightly, faster digits on the right
      const delay = (digits.length - 1 - i) * 60;
      const duration = 900 + i * 60;

      requestAnimationFrame(() => {
        setTimeout(() => {
          const offset = -((items.length - 1) * LINE_HEIGHT);
          track.style.transition = `transform ${duration}ms cubic-bezier(0.15, 0.85, 0.35, 1.0)`;
          track.style.transform = `translateY(${offset}em)`;
        }, delay);
      });
    });

    // Fade back to gray after all digits land
    const totalDuration = 900 + (digits.length - 1) * 60 + (digits.length - 1) * 60 + 400;
    setTimeout(() => {
      el.style.transition = 'color 0.6s ease';
      el.style.color = '';
    }, totalDuration);
  }
</script>
