---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const {
  title = '/brag directory',
  description = 'A public directory of people who have /brag pages. Add yours with a pull request.',
  hideFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anek+Bangla:wght@100..800&family=Lato:ital,wght@0,300;0,400;0,700;1,300;1,400;1,700&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-background text-gray-900 antialiased font-body">
    <!-- Left sidebar -->
    <aside
      class="fixed top-0 left-0 h-screen w-1/4 flex flex-col px-6 justify-center z-40 sidebar"
    >

        <h2 class="text-xl text-gray-400 leading-relaxed font-light font-display">
            Resumés are the standard<br />You are above the standard <span class="text-gray-900">\brag about it</span>
        </h2>

      <nav class="flex flex-col gap-1 text-sm mt-8">
        <a
          href="/"
          class={`w-48 px-3 py-1.5 transition-colors ${Astro.url.pathname === '/' ? 'bg-blue-500/15 text-blue-500' : 'text-gray-400 hover:text-gray-900'}`}
          >List</a
        >
        <a
          href="/about"
          class={`w-48 px-3 py-1.5 transition-colors ${Astro.url.pathname === '/about' ? 'bg-blue-500/15 text-blue-500' : 'text-gray-400 hover:text-gray-900'}`}
          >About</a
        >
        <a
          href="/submit"
          class={`w-48 px-3 py-1.5 transition-colors ${Astro.url.pathname === '/submit' ? 'bg-blue-500/15 text-blue-500' : 'text-gray-400 hover:text-gray-900'}`}
          >Submit</a
        >
      </nav>
    </aside>

    <!-- Main content area -->
    <div class="ml-[25%] min-h-screen flex flex-col">
      <main class="flex-1 px-8 sm:px-12 py-10">
        <slot />
      </main>
