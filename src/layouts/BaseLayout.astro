      }
    </div>

    <!-- Blur fade overlays (content area only) -->
    <div class="fade-top" id="fade-top"></div>
    <div class="fade-bottom" id="fade-bottom"></div>
  </body>
</html>

<script>
  const fadeTop = document.getElementById('fade-top');
  const fadeBottom = document.getElementById('fade-bottom');
  const sidebar = document.querySelector('.sidebar');
  const threshold = 40;
  let scrollTimer: ReturnType<typeof setTimeout> | null = null;

  function updateFades() {
    const scrollY = window.scrollY;
    const maxScroll = document.documentElement.scrollHeight - window.innerHeight;

    fadeTop?.classList.toggle('visible', scrollY > threshold);
    fadeBottom?.classList.toggle('visible', scrollY < maxScroll - threshold);

    sidebar?.classList.add('is-scrolling');
    if (scrollTimer) clearTimeout(scrollTimer);
    scrollTimer = setTimeout(() => sidebar?.classList.remove('is-scrolling'), 800);
  }

  updateFades();
  window.addEventListener('scroll', updateFades, { passive: true });
</script>

<style>
  /* masked shadow — only where the line is visible */
  .sidebar::before {
    content: '';
    position: absolute;
    top: 0;
    right: -20px;
    width: 20px;
    height: 100%;
    background: rgba(59, 130, 246, 0.06);
    filter: blur(12px);
    opacity: 0;
    transition: opacity 0.2s ease;
    mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      black 50%,
      transparent 80%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      black 50%,
      transparent 80%,
      transparent 100%
    );
  }

  .sidebar.is-scrolling::before {
    opacity: 1;
  }

  /* crisp line — gray at rest, blue while scrolling */
  .sidebar::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 1px;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      rgb(209, 213, 219) 50%,
      transparent 80%,
      transparent 100%
    );
    transition: opacity 0.2s ease;
  }

  .sidebar.is-scrolling::after {
    background: linear-gradient(
      to bottom,
      transparent 0%,
      transparent 20%,
      rgb(147, 197, 253) 50%,
      transparent 80%,
      transparent 100%
    );
  }


  .fade-top,
  .fade-bottom {
    position: fixed;
    left: 25%;
    right: 0;
    height: 6rem;
    pointer-events: none;
    z-index: 30;
    opacity: 0;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .fade-top {
    top: 0;
    background: linear-gradient(to bottom, var(--color-background) 0%, transparent 100%);
  }

  .fade-bottom {
    bottom: 0;
    background: linear-gradient(to top, var(--color-background) 0%, transparent 100%);
    -webkit-mask-image: linear-gradient(to top, black 0%, transparent 100%);
  }

  .fade-top.visible,
  .fade-bottom.visible {
    opacity: 1;
  }

  .footer-carousel-wrapper {
    width: 100%;
    position: relative;
    padding: 0.75rem 0;
  }

  .footer-carousel {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 30%, black 40%, black 60%, transparent 70%);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 30%,
      black 40%,
      black 60%,
      transparent 70%
    );
  }

  .footer-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: footer-scroll 20s linear infinite;
  }

  .footer-track > * {
    margin-right: 3rem;
  }

  .footer-carousel:hover .footer-track {
    animation-play-state: paused;
  }

  .footer-submit {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .submit-btn {
    background: rgba(191, 219, 254, 0.15);
    color: #bfdbfe;
    padding: 0.3rem 1rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .submit-btn:hover {
    background: rgba(191, 219, 254, 0.25);
  }

  .footer-carousel-wrapper:last-of-type .footer-track {
    animation-name: footer-scroll-reverse;
  }

  @keyframes footer-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-12.5%);
    }
  }

  @keyframes footer-scroll-reverse {
    from {
      transform: translateX(-12.5%);
    }
    to {
      transform: translateX(0);
    }
  }
</style>
