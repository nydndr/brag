---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const {
  title = '/brag directory',
  description = 'A public directory of people who have /brag pages. Add yours with a pull request.',
  hideFooter = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anek+Bangla:wght@100..800&family=Source+Code+Pro:ital,wght@0,200..900;1,200..900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col antialiased">
    <header class="border-b border-blue-500">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a
          href="/"
          class="font-semibold text-sm tracking-tight hover:text-blue-500 transition-colors"
          >\brag pages</a
        >
        <nav class="flex items-center gap-4 text-sm">
          <a href="/about" class="text-gray-400 hover:text-gray-900 transition-colors px-3 py-1"
            >About</a
          >
          <a
            href="/submit"
            class="bg-blue-500/15 text-blue-500 px-3 py-1 hover:bg-blue-500/25 transition-colors"
            >Submit</a
          >
        </nav>
      </div>
    </header>
    <main class="flex-1 max-w-6xl mx-auto w-full px-4 sm:px-6 py-10">
      <slot />
    </main>
    {
      !hideFooter && (
        <footer class="font-mono uppercase bg-blue-800 text-white py-16 space-y-8 mt-12 border-t border-blue-200">
          <div class="footer-carousel-wrapper">
            <div class="footer-carousel">
              <div class="footer-track">
                <p>An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
                <p aria-hidden="true">An idea by Aaron Francis and Ian Landsman</p>
              </div>
            </div>
          </div>

          <div class="footer-submit">
            <a href="/submit" class="submit-btn">
              Submit yours
            </a>
          </div>

          <div class="footer-carousel-wrapper">
            <div class="footer-carousel">
              <div class="footer-track">
                <p>Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
                <p aria-hidden="true">Website built by Dandara</p>
              </div>
            </div>
          </div>
        </footer>
      )
    }
  </body>
</html>

<style>
  .footer-carousel-wrapper {
    width: 100%;
    position: relative;
    padding: 0.75rem 0;
  }

  .footer-carousel {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 30%, black 40%, black 60%, transparent 70%);
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 30%,
      black 40%,
      black 60%,
      transparent 70%
    );
  }

  .footer-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: footer-scroll 20s linear infinite;
  }

  .footer-track > * {
    margin-right: 3rem;
  }

  .footer-carousel:hover .footer-track {
    animation-play-state: paused;
  }

  .footer-submit {
    display: flex;
    justify-content: center;
    padding: 1rem 0;
  }

  .submit-btn {
    background: rgba(191, 219, 254, 0.15);
    color: #bfdbfe;
    padding: 0.3rem 1rem;
    text-decoration: none;
    transition: background 0.15s;
  }

  .submit-btn:hover {
    background: rgba(191, 219, 254, 0.25);
  }

  .footer-carousel-wrapper:last-of-type .footer-track {
    animation-name: footer-scroll-reverse;
  }

  @keyframes footer-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-12.5%);
    }
  }

  @keyframes footer-scroll-reverse {
    from {
      transform: translateX(-12.5%);
    }
    to {
      transform: translateX(0);
    }
  }
</style>
